    "ai.idle.subtitle": {
      "comment": "Subtitle on the AI idle screen before the user generates suggestions",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Type what you're in the mood for, or tap ✦ to get suggestions based on your watching, plan to watch, and completed lists."

        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Digite o que você quer assistir, ou toque em ✦ para receber sugestões baseadas nas suas listas de assistindo, quero assistir e concluídos."
          }
        }
      }
    },

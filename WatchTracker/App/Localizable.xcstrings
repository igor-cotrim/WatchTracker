    "ai.empty_watchlist.subtitle": {
      "comment": "Message when watchlist is empty and AI cannot generate suggestions",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add movies and shows to your watchlist first so we can learn your taste."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione filmes e séries à sua lista primeiro para que possamos aprender seu gosto."
          }
        }
      }
    },
